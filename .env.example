POSTGRES_DB=backlog
POSTGRES_USER=backlog
POSTGRES_PASSWORD=backlog
POSTGRES_DSN=postgres://backlog:backlog@db:5432/backlog?sslmode=disable

SESSION_SECRET=change-me-use-at-least-32-random-bytes

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-boot
ADMIN_DISPLAY_NAME=Admin

API_PORT=8080
PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# --- OIDC (optional) ---
# Leave all OIDC_* unset to disable SSO.
# OIDC_ISSUER_URL=https://your-issuer.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=http://localhost:8080/api/v1/auth/oidc/callback
# OIDC_SCOPES=openid,profile,email,groups
# Map a group claim value to IsSystemAdmin. Leave OIDC_ADMIN_GROUP blank to
# disable auto-admin mapping.
# OIDC_ADMIN_GROUP=backlog-admins
# OIDC_GROUPS_CLAIM=groups
# OIDC_EMAIL_CLAIM=email
# OIDC_NAME_CLAIM=name
# OIDC_PROVIDER_NAME=Okta
